# cctv-ce-agent config — copy to /etc/cctv-ce/.env (chmod 600). NEVER commit real values.
# Secrets/IDs are injected at install time via env; this file documents the keys only.

SERVER_ID=                                  # required, e.g. songkhla1 / samui1 / bkk1
API_KEY=                                     # Bearer token for the ingest endpoint
INGEST_URL=                                  # e.g. https://YOUR-CE-HOST/api/v1/camera-ce  (empty = dry-run stdout)
CAMERAS_FILE=/etc/cctv-ce/cameras.csv        # path to camera list (id,ip)

# Egress probe (RTSP server -> AWS). TCP SYN, NOT ICMP. Do NOT use aws.amazon.com (CloudFront edge).
AWS_PROBE_HOST=s3.ap-southeast-1.amazonaws.com
AWS_PROBE_PORT=443

PING_COUNT=100                               # fping samples per camera
PING_INTERVAL_MS=200                         # fping interval
COLLECT_TX=1                                  # 1 = per-camera TX via conntrack (needs nf_conntrack_acct=1)
